# Copy this file to .env and fill in real values before running the app.
# Never commit the real .env file — it is listed in .gitignore.

# ── LLM ─────────────────────────────────────────────────────────────
# API key for the Groq LLM service (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# ── Owner dashboard ──────────────────────────────────────────────────
# Password used to authenticate owner-facing API endpoints
OWNER_PASSWORD=change-me-to-a-strong-secret

# ── Shopify integration ──────────────────────────────────────────────
# Your Shopify store domain, e.g. my-store.myshopify.com (no https://)
SHOPIFY_STORE_URL=your-store.myshopify.com

# Private app / custom app Admin API access token from Shopify Partners
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
